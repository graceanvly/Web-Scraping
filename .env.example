APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bid
DB_USERNAME=root
DB_PASSWORD=

# Bid listing (/bids): default CREATED window in days (faster when the Oracle bid table is huge).
# Omit or use 180 = only bids from the last N days unless ?historical=1 or the "Include historical" checkbox is checked.
# Set to 0 to disable the CREATED window by default (not recommended on very large production tables).
# SCRAPER_BID_LISTING_RECENT_DAYS=180

# Deep link base for "open on main site" ShowBid URLs (must end with ShowBid/ segment; slug is appended).
# SCRAPER_STATEANDFEDERALBIDS_SHOWBID_BASE_URL=https://www.stateandfederalbids.com/bids/ShowBid/
# ShowBid URL ends with the ODS bid PK (not necessarily this app’s BID_SEQ). Use numeric Bid.THIRD_PARTY_IDENTIFIER when set.
# Only if this DB shares the same bid PKs as production may you enable trusting local Bid.ID:
# SCRAPER_STATEANDFEDERALBIDS_SHOWBID_TRUST_LOCAL_BID_ID=true

# Reference tables / bid enrichment (scraping). Align with Oracle or local schema.
SCRAPER_CATEGORY_TABLE=category
SCRAPER_STATE_TABLE=state
# Scraper-managed bid URL list (Manage Bid URLs, Scrape All, failed restore).
# Use BID_URL on Oracle — do NOT set SCRAPER_BID_URL_TABLE=BIDURL (legacy ODS; read-only).
# SCRAPER_BID_URL_TABLE=BID_URL
# SCRAPER_BID_URL_ID_COLUMN=ID
# SCRAPER_BID_URL_URL_COLUMN=URL
# SCRAPER_BID_URL_NAME_COLUMN=NAME
# SCRAPER_BID_URL_USER_ID_COLUMN=USER_ID
# SCRAPER_BID_URL_SEQUENCE=BID_URL_SEQ
# Visit log: BID_URL_HISTORY on Oracle, bid_url_history on MySQL dev.
# SCRAPER_BID_URL_HISTORY_TABLE=BID_URL_HISTORY
# SCRAPER_BID_URL_HISTORY_ID_COLUMN=ID
# SCRAPER_BID_URL_HISTORY_SEQUENCE=BID_URL_HISTORY_SEQ
# When true, failed scrapes move the row from BID_URL into failed_bid_urls. Default false.
# SCRAPER_QUARANTINE_URL_ON_SCRAPE_ERROR=false
# SCRAPER_REQUIRE_ENDDATE_FOR_SAVE=true
# SCRAPER_BID_SKIP_URL_IF_SCRAPED_TODAY=false
# Entity master list for ENTITYID on new bids:
# Matching order: Bid URL name, bid email, non-portal URL host (listing/detail) vs entity website/domain, then fuzzy ISSUING_ORGANIZATION (+ patterns).
SCRAPER_ENTITY_RESOLVE_ENABLED=true
SCRAPER_ENTITY_TABLE=entity
SCRAPER_ENTITY_ID_COLUMN=id
SCRAPER_ENTITY_EMAIL_COLUMNS=email
SCRAPER_ENTITY_NAME_COLUMNS=name
# Optional: comma-separated website URL columns on the entity table (homepage, portal URL, etc.).
SCRAPER_ENTITY_WEBSITE_COLUMNS=

# OpenAI (Guzzle). Extract sends large page/PDF excerpts; timeout is total request time in seconds.
OPENAI_HTTP_TIMEOUT=300
OPENAI_HTTP_TIMEOUT_REWRITE=120
OPENAI_HTTP_CONNECT_TIMEOUT=30
# Optional: tighter wall-clock only for scrape-all/stream bulk AI extract (defaults to OPENAI_HTTP_TIMEOUT).
# OPENAI_HTTP_TIMEOUT_BULK=240
# OPENAI_EXTRACT_HEARTBEAT_SEC throttles “still running” SSE pings during long OpenAI extracts (scraped streamed chat API when using scrape-all/stream UI; CURL progress ping only when OPENAI_EXTRACT_HEARTBEAT=true below).
# OPENAI_EXTRACT_HEARTBEAT_SEC=22
# Max seconds per low-level fread wait on the OpenAI SSE stream (heartbeat between chunks when stream_select is unavailable).
# OPENAI_SSE_STREAM_READ_TIMEOUT_SEC=2
# Optional: CURL progress pings (ext-curl only; conflicts with streamed extract — scrape UI uses streamed API pings instead).
# OPENAI_EXTRACT_HEARTBEAT=false
# OpenAI HTTP transport: default (unset) = stream handler in config/services.php — avoids curl_setopt_array
# errors with Guzzle's CurlHandler on some PHP+libcurl builds. Set OPENAI_HTTP_HANDLER=curl only to force ext-curl.
# After changing, run: php artisan config:clear  (or config:cache to bake .env into bootstrap/cache/config.php)
# OPENAI_HTTP_HANDLER=curl
# Max wall-clock per Bid URL during scrape-all / stream (fetch + AI + DB). Title rewrite is skipped if near budget.
SCRAPER_URL_MAX_SECONDS=480
# Bids UI “Single per-URL max (5 min)” on Scrape All sends ?single_url_max=1 — uses a hard 300s cap per URL for that run (fetch + AI + saves; does not change SCRAPER_URL_MAX_SECONDS).
SCRAPER_TITLE_REWRITE_RESERVE_SECONDS=90
SCRAPER_REWRITE_MAX_TITLES=120
# Titles rewritten per OpenAI call during scrape-all/stream (SSE updates between batches when count exceeds this chunk size).
# SCRAPER_TITLE_REWRITE_CHUNK=10
# Bulk scrape/stream: smaller excerpts = shorter OpenAI time (defaults in config/scraper.php).
# SCRAPER_AI_BULK_PDF_TEXT_CHARS=14000
# SCRAPER_AI_BULK_LISTING_TEXT_CHARS=20000
# After per-page caps, trims combined bid_page excerpts (characters).
# SCRAPER_AI_BULK_PAGES_TOTAL_CHARS=34000
# Max wall-clock per single bulk AI extract call. Bounds a stalled/slow OpenAI stream so one URL can't consume nearly the whole per-URL budget; the URL is skipped (not failed) and retried next run. Still capped by remaining per-URL budget.
# SCRAPER_AI_BULK_EXTRACT_MAX_SECONDS=150
# Seconds reserved for saving bids after title rewrite. Rewrite batches are each capped to (remaining per-URL budget - this), and stop early (keeping original titles) when the budget runs low, so rewrite can't push a URL past its time limit.
# SCRAPER_SAVE_RESERVE_SECONDS=25
# Listing/detail PDF: SCRAPER_PDF_TIMEOUT / SCRAPER_PDF_PARSE_TIMEOUT (seconds, see config/scraper.php); slow trickle CDNs also respect per-URL SCRAPER_URL_MAX_SECONDS via chunked reads.
# SCRAPER_PDF_TIMEOUT=60
# SCRAPER_PDF_PARSE_TIMEOUT=45
# PDFs larger than this skip pure-PHP Smalot (often very slow/hangs on multi‑MB scans); smaller PDFs still use Smalot first, then timed pdftotext if empty.
# SCRAPER_PDF_SMALOT_MAX_BYTES=524288
# Batch/stream: Puppeteer subprocess cap for URLs that only need Chrome due to thin listing text (<500 chars, HTTP OK, not SPA).
# Default matches config scraper.batch_thin_listing_headless_max_sec (SSE quiescence while Node runs otherwise ~20–85s).
# SCRAPER_BATCH_THIN_HEADLESS_MAX_SEC=42
# Set true to skip headless entirely for that case (fast; JS-only portals may yield nothing).
# SCRAPER_BATCH_SKIP_THIN_HEADLESS=false
#
# Puppeteer / Chrome on Linux (EC2): read via config/scraper.php so php artisan config:cache still applies.
# Crashpad “--database is required” / launch failures: try SCRAPER_CHROME_SINGLE_PROCESS=true and a writable
# SCRAPER_CHROME_USER_DATA_DIR=/tmp/chrome-scraper (mkdir first; owned by php-fpm user). Optional: SCRAPER_CHROME_HEADLESS=shell
# SCRAPER_CHROME_SINGLE_PROCESS=true
# SCRAPER_CHROME_USER_DATA_DIR=/tmp/chrome-scraper
# SCRAPER_CHROME_HEADLESS=shell
# PUPPETEER_EXECUTABLE_PATH=/path/to/chrome
# SSE status line interval (seconds) while Chrome subprocess runs (heavy Bonfire can take 60–120s with no other updates).
# SCRAPER_PUPPETEER_SSE_PULSE_SEC=15

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
