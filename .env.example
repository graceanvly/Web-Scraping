APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bid
DB_USERNAME=root
DB_PASSWORD=

# Reference tables / bid enrichment (scraping). Align with Oracle or local schema.
SCRAPER_CATEGORY_TABLE=category
SCRAPER_STATE_TABLE=state
# Entity master list for ENTITYID on new bids:
# Matching order: bid email equals entity email, bid URL hostname vs entity email/domain or WEBSITE column, then fuzzy ISSUING_ORGANIZATION (+ patterns).
SCRAPER_ENTITY_RESOLVE_ENABLED=true
SCRAPER_ENTITY_TABLE=entity
SCRAPER_ENTITY_ID_COLUMN=id
SCRAPER_ENTITY_EMAIL_COLUMNS=email
SCRAPER_ENTITY_NAME_COLUMNS=name
# Optional: comma-separated website URL columns on the entity table (homepage, portal URL, etc.).
SCRAPER_ENTITY_WEBSITE_COLUMNS=

# OpenAI (Guzzle). Extract sends large page/PDF excerpts; timeout is total request time in seconds.
OPENAI_HTTP_TIMEOUT=300
OPENAI_HTTP_TIMEOUT_REWRITE=120
OPENAI_HTTP_CONNECT_TIMEOUT=30
# Optional: tighter wall-clock only for scrape-all/stream bulk AI extract (defaults to OPENAI_HTTP_TIMEOUT).
# OPENAI_HTTP_TIMEOUT_BULK=240
# Seconds between “still running…” SSE pings while OpenAI extracts (curl progress hook; ignored without ext-curl).
# OPENAI_EXTRACT_HEARTBEAT_SEC=22
# Set false if you see curl_setopt_array “invalid cURL options” on extract (disables SSE pings only).
# OPENAI_EXTRACT_HEARTBEAT=true
# Max wall-clock per Bid URL during scrape-all / stream (fetch + AI + DB). Title rewrite is skipped if near budget.
SCRAPER_URL_MAX_SECONDS=480
SCRAPER_TITLE_REWRITE_RESERVE_SECONDS=90
SCRAPER_REWRITE_MAX_TITLES=120
# Titles rewritten per OpenAI call during scrape-all/stream (SSE updates between batches when count exceeds this chunk size).
# SCRAPER_TITLE_REWRITE_CHUNK=10
# Bulk scrape/stream: smaller excerpts = shorter OpenAI time (defaults in config/scraper.php).
# SCRAPER_AI_BULK_PDF_TEXT_CHARS=14000
# SCRAPER_AI_BULK_LISTING_TEXT_CHARS=20000
# After per-page caps, trims combined bid_page excerpts (characters).
# SCRAPER_AI_BULK_PAGES_TOTAL_CHARS=34000
# Batch/stream: Puppeteer subprocess cap for URLs that only need Chrome due to thin listing text (<500 chars, HTTP OK, not SPA).
# Default matches config scraper.batch_thin_listing_headless_max_sec (SSE quiescence while Node runs otherwise ~20–85s).
# SCRAPER_BATCH_THIN_HEADLESS_MAX_SEC=42
# Set true to skip headless entirely for that case (fast; JS-only portals may yield nothing).
# SCRAPER_BATCH_SKIP_THIN_HEADLESS=false

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
